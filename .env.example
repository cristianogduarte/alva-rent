# ============================================================
# ALVA Rent — variáveis de ambiente
# Copie pra .env.local e preencha. NUNCA commite .env.local.
# ============================================================

# ─── Supabase ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # NUNCA expor no client

# ─── Banco Inter (Cobrança v3) ────────────────────────────
INTER_BASE_URL=https://cdpj.partners.bancointer.com.br
# Sandbox: https://cdpj-sandbox.partners.uatinter.co
INTER_CLIENT_ID=
INTER_CLIENT_SECRET=
INTER_CONTA_CORRENTE=
# Certificados em base64. Gere com: base64 -w0 cert.crt
INTER_CERT_PEM_BASE64=
INTER_KEY_PEM_BASE64=
INTER_SCOPE=boleto-cobranca.read boleto-cobranca.write webhook.read webhook.write
# Gere uma string aleatória (32+ chars). Configure no painel Inter como assinatura do webhook.
INTER_WEBHOOK_SECRET=

# ─── Z-API (WhatsApp) ─────────────────────────────────────
ZAPI_INSTANCE=
ZAPI_TOKEN=
ZAPI_SECURITY_TOKEN=

# ─── Resend (E-mail) ──────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=cobranca@alvarent.com.br

# ─── App ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Em produção: https://app.alvarent.com.br
# Site institucional/marketing: https://alvarent.com.br
# ALVA ONE (raiz com todos os negócios): https://alvaone.com.br
NEXT_PUBLIC_APP_NAME="ALVA Rent"
NEXT_PUBLIC_APP_BRAND="ALVA ONE"

# ─── Observabilidade (opcional) ───────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_VERCEL_ENV=development
